rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{document} {
      allow read, write: if request.auth != null;
    }

    match /campaigns/{document} {
      allow read, write: if request.auth != null;
    }

    match /influencers/{document} {
      allow read, write: if request.auth != null;
    }

    match /sampleActions/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
